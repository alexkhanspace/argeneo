# =============================================================================
# Argeneo — Production environment file (TEMPLATE)
# =============================================================================
# 1. Copy this file to the server:   /etc/argeneo/argeneo.env
# 2. Replace every CHANGE_ME_* placeholder with a real value.
# 3. Lock it down:                   chmod 600 /etc/argeneo/argeneo.env
#                                    chown root:argeneo /etc/argeneo/argeneo.env
#
# This file is read by the systemd unit (EnvironmentFile=) and injected into
# the Spring Boot process. It is NOT committed to git — only this *.example is.
#
# Generate strong secrets on your Mac, e.g.:
#   JWT  :  openssl rand -base64 48
#   DB pw:  openssl rand -base64 24 | tr -d '/+=' | head -c 32
# =============================================================================

# --- Security / JWT --------------------------------------------------------
# MUST be >= 32 bytes. Used to sign auth tokens. Rotating it logs everyone out.
ARGENEO_SECURITY_JWT_SECRET=CHANGE_ME_jwt_secret_at_least_32_bytes_long_use_openssl_rand

# --- Database --------------------------------------------------------------
# Postgres listens on localhost only (see provision.sh / postgresql.conf).
# The password below MUST match the role password created in postgres/setup.sql.
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/argeneo
SPRING_DATASOURCE_USERNAME=argeneo
SPRING_DATASOURCE_PASSWORD=CHANGE_ME_strong_db_password

# --- Bootstrap super-admin -------------------------------------------------
# Created once on first startup if no admin exists. Change the password after
# first login, or at minimum use a strong one here.
ARGENEO_BOOTSTRAP_ADMIN_EMAIL=admin@argeneo.fr
ARGENEO_BOOTSTRAP_ADMIN_PASSWORD=CHANGE_ME_strong_admin_password

# --- CORS ------------------------------------------------------------------
# Origin(s) allowed to call the API from a browser. In prod the SPA and API are
# same-origin behind nginx, but the browser still sends an Origin header, so the
# public URL(s) MUST be listed here or Spring rejects with "Invalid CORS request".
# Comma-separated. The yaml default (http://localhost:5173) is for local dev only.
ARGENEO_SECURITY_CORS_ALLOWEDORIGINS=https://argeneo.fr,https://www.argeneo.fr

# --- HTTP server -----------------------------------------------------------
# Backend listens on this port; nginx proxies /api -> 127.0.0.1:8080.
# Keep 8080 unless you also change the nginx proxy_pass + systemd notes.
SERVER_PORT=8080

# Make Spring activate the production profile (optional but recommended).
SPRING_PROFILES_ACTIVE=prod

# --- JVM options -----------------------------------------------------------
# This VPS has ~3.5 GiB RAM and NO swap. Cap the heap so the OOM-killer never
# fires. 1g is comfortable for Spring Boot + Postgres co-located on the box.
# Tune up if you add RAM. MaxRAMPercentage is an alternative to a fixed -Xmx.
JAVA_OPTS=-Xms256m -Xmx1g -XX:+UseG1GC -XX:MaxGCPauseMillis=200 -Djava.security.egd=file:/dev/./urandom
